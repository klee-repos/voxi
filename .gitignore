# ─── OS / editor noise ───────────────────────────────────────────────
.DS_Store
*.swp
*.swo
.vscode/
.idea/

# ─── Node / Bun ──────────────────────────────────────────────────────
node_modules/
# (bun.lock IS committed — it's the lockfile)

# ─── TypeScript build output ─────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ─── Expo / React Native ─────────────────────────────────────────────
.expo/
web-build/
# Prebuild-generated native projects (regenerated by `expo prebuild`)
ios/
android/

# ─── Env & secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example
.env.local
.gcloud/
.gcp/
service-account*.json
*.p8
*.pem
*.p12

# ─── Python (services/voice-bot) ─────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─── Terraform / infra (infra/terraform has its own .gitignore too) ──
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
crash.*.log

# ─── Local runtime data (never commit local DB / rendered media) ─────
.voxi-data/

# ─── Tests / tapes / coverage ────────────────────────────────────────
e2e/fixtures/tapes/*.live.json
e2e/artifacts/
coverage/
# E2E runner result logs — write-only run output (Bun.write), regenerated each run
e2e/web/.*-result.txt

# ─── Logs ────────────────────────────────────────────────────────────
*.log

# ─── Backup / temp files ─────────────────────────────────────────────
*.orig
*.bak
*.tmp

# ─── AI assistant instructions (local-only for now) ──────────────────
CLAUDE.md

# Isolated app-icon generator deps (scripts/icons is not a workspace)
scripts/icons/node_modules/

# Museum eval fixtures — large binaries, re-fetched + sha1-verified via bun run museum:fixtures (manifest is committed)
e2e/judge/museum/fixtures/
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules

# Local design-system → claude.ai/design sync tooling (personal, not needed to build/run Voxi)
.design-sync/

# full-send scratchpad (plans/RCAs/proof artifacts — never committed)
.full-send/
.full-send
