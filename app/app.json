{
  "expo": {
    "name": "Voxi",
    "slug": "voxi",
    "version": "1.0.0",
    "scheme": "voxi",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0B0B14",
    "splash": {
      "backgroundColor": "#0B0B14",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kvnlee.voxi",
      "appleTeamId": "DRJEJC9KRM",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Voxi uses the camera to photograph objects for the Guide.",
        "NSMicrophoneUsageDescription": "Voxi uses the microphone for voice chat with the Guide.",
        "NSLocationWhenInUseUsageDescription": "Voxi's real-time voice chat uses a networking component that may check your location to keep the voice connection reliable. Voxi does not track or store your location.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "audio"
        ],
        "NSAllowsLocalNetworking": true
      },
      "bitcode": false,
      "buildNumber": "7"
    },
    "android": {
      "package": "com.kvnlee.voxi",
      "adaptiveIcon": {
        "backgroundColor": "#0B0B14"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B0B14",
          "resizeMode": "contain"
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Voxi uses the camera to photograph objects for the Guide.",
          "enableMicrophonePermission": true,
          "microphonePermissionText": "Voxi uses the microphone for voice chat with the Guide."
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Voxi uses the camera for the Guide.",
          "microphonePermission": "Voxi uses the microphone for voice chat with the Guide."
        }
      ],
      "expo-audio",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "organization": "kvnlee",
          "project": "voxi-app"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "clerkPublishableKey": "${EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY}",
      "apiBaseUrl": "${EXPO_PUBLIC_API_BASE_URL}",
      "pipecatConnectUrl": "${EXPO_PUBLIC_PIPECAT_CONNECT_URL}",
      "sentryDsn": "${EXPO_PUBLIC_SENTRY_DSN}",
      "router": {},
      "eas": {
        "projectId": "12b59473-2cb0-4703-9003-7b1e294f17f3"
      }
    },
    "owner": "klee248"
  }
}
