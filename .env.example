# Voxi live-tier credentials. COPY this to `.env.local` (gitignored) and fill in.
# NEVER paste these values into chat — just fill this file and tell me "go".

# ── GCP: ALREADY WORKING via the gcloud CLI (no ADC, no service-account key) ──────
# Auth is a bearer from `gcloud auth print-access-token`. Vertex Gemini (vision ID) + Cloud Vision are live.
# Leave these as-is unless you want a different project/region.
GCP_PROJECT=your-gcp-project
GCP_LOCATION=us-central1                      # Cloud Vision + the multimodal embedding (single-region).
GEMINI_MODEL=gemini-3.5-flash                 # vision identification (Vertex).
GEMINI_LOCATION=global                        # generative Gemini endpoint — gemini-3.5-flash is NOT on us-central1.

# ── GENERATIVE LAYER: GLM-5.2 (narration/facts/research/dossier/script) + Firecrawl grounding ───
# The five generative use cases run on GLM-5.2 (z.ai, OpenAI-compatible). Grounding flows through Firecrawl (real
# page markdown → GLM extracts verbatim-quoted facts the honesty gate verifies). BOTH REQUIRED in prod (the
# entrypoints assertProdKeys at boot on Cloud Run); absent locally, the cascade degrades to honest-empty.
GLM_API_KEY=                                   # z.ai → API keys. The generative model + the durable brain (GLM-5-Turbo).
GLM_BASE_URL=https://api.z.ai/api/paas/v4/     # international; China: https://open.bigmodel.cn/api/paas/v4/
FIRECRAWL_API_KEY=                             # firecrawl.dev → API keys. REQUIRED: the grounding substrate.

# ── GIVE ME THESE NOW: auth + voice ──────────────────────────────────────────────
# Clerk (auth). Create an app at dashboard.clerk.com → API keys.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWT_KEY=                       # optional: PEM public key for fully networkless JWT verify

# ElevenLabs (Voxi's spoken voice + the 2-host podcast audio). elevenlabs.io → profile → API key.
ELEVENLABS_API_KEY=

# Deepgram (STT for the live voice conversation). deepgram.com → API keys.
DEEPGRAM_API_KEY=

# OpenAI (LLM for the live voice conversation — the Guide's reasoning). The BFF generative layer already uses it.
OPENAI_API_KEY=

# LiveKit (realtime voice media plane). The BFF mints per-session LiveKit tokens; the @livekit/react-native client
# connects; the voice-bot (livekit-agents Worker) is dispatched into the room. Dev: scripts/dev.sh runs a local
# LiveKit dev server (devkey/secret) + writes these. Prod: a LiveKit Cloud project (or self-host) + a real key/secret.
# All three required — the BFF 503s on /v1/voice/session if any is unset (never bills a minute for a doomed session).
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── LATER: full backend deploy (Cloud Run + Cloud SQL/AlloyDB, etc.) ──────────────
VOXI_URL_SIGNING_KEY=                # I'll generate a strong random one if left blank
# DATABASE_URL / EVE_SELF_URL are produced by the deploy scripts, not by you.

# ── LATER: iOS + App Store (needs your Mac + Xcode + an Apple Developer account) ──
# Subscriptions are StoreKit 2 DIRECT — NO billing vendor (RevenueCat removed). The server verifies
# transactions/notifications with Apple's PUBLIC root certs (no secret needed for verification). An App Store
# Connect API key is only needed to CALL the App Store Server API and comes with the Apple Developer setup.
APPSTORE_CONNECT_ISSUER_ID=          # App Store Connect → Users and Access → Integrations → Keys
APPSTORE_CONNECT_KEY_ID=
APPSTORE_CONNECT_PRIVATE_KEY=        # the .p8 contents (or a path)
# APPLE_TEAM_ID / bundle id are set during `eas build` on your Mac.

# ── Observability: structured logs + traces (PLAN §11). See docs/observability.md. ────────────────
# UNSET = structured JSON logs to stdout only (always on, needs no infra). Prod backend = Google Cloud
# Operations: on Cloud Run, stdout → Cloud Logging is AUTOMATIC (leave these unset for logs). Set the two
# OTLP vars only to export TRACES — LOCAL: the dev stack (`docker compose -f
# infra/observability/docker-compose.yml up -d`); CLOUD: an OTel Collector sidecar (googlecloud exporter) or
# GCP's OTLP endpoint. RCA is done against Cloud Logging via `gcloud` (no query MCP — see docs).
OTEL_EXPORTER_OTLP_ENDPOINT=         # LOCAL: http://localhost:4318 · CLOUD: http://localhost:4318 (collector sidecar) or https://telemetry.googleapis.com
OTEL_EXPORTER_OTLP_HEADERS=          # LOCAL: blank · CLOUD: set by the sidecar, or a GCP bearer token + x-goog-user-project
LOG_LEVEL=info                       # debug | info | warn | error | fatal
